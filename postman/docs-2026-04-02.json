                  "raw": "{{BASE_URL}}/meta/ad-sets?ad_account_id={{AD_ACCOUNT_ID}}&campaign_id={{CAMPAIGN_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "ad-sets"],
                  "query": [
                    { "key": "ad_account_id", "value": "{{AD_ACCOUNT_ID}}" },
                    { "key": "campaign_id", "value": "{{CAMPAIGN_ID}}" },
                    { "key": "after", "value": "", "disabled": true }
