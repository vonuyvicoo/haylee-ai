            {
              "name": "Search Interests",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{BASE_URL}}/meta/ad-sets/search/interests?type=adinterest&class=interests&query=Insurance",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "ad-sets", "search", "interests"],
                  "query": [
                    { "key": "type", "value": "adinterest", "description": "adinterest | adTargetingCategory" },
                    { "key": "class", "value": "interests", "description": "interests | behaviors" },
                    { "key": "query", "value": "Insurance" }
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Create Ad Set",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"AI Ad Set\",\n  \"campaign_id\": \"{{CAMPAIGN_ID}}\",\n  \"strategy\": \"CAMPAIGN_BUDGET\",\n  \"billing_event\": \"IMPRESSIONS\",\n  \"optimization_goal\": \"PAGE_LIKES\",\n  \"start_time\": \"2026-04-10T00:00:00Z\",\n  \"end_time\": \"2026-05-10T00:00:00Z\",\n  \"targeting\": {\n    \"geo_locations\": {\n      \"countries\": [\"PH\"]\n    },\n    \"targeting_automation\": {\n      \"advantage_audience\": 1\n    },\n    \"flexible_spec\": [\n      {\n        \"interests\": [\n          { \"id\": \"6003353637860\", \"name\": \"Life Insurance\" }\n        ]\n      }\n    ]\n  }\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{BASE_URL}}/meta/ad-sets?ad_account_id={{AD_ACCOUNT_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "ad-sets"],
                  "query": [
                    { "key": "ad_account_id", "value": "{{AD_ACCOUNT_ID}}" }
                  ]
                },
                "description": "strategy: CAMPAIGN_BUDGET | ADSET_BUDGET\ndaily_budget / lifetime_budget: required when strategy=ADSET_BUDGET (in cents)\nbilling_event: IMPRESSIONS | CLICKS | etc.\noptimization_goal: PAGE_LIKES | LEAD_GENERATION | LINK_CLICKS | etc."
              },
              "response": []
            },
