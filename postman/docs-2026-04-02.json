                    { "key": "file", "type": "file", "src": "" }
                  ]
                },
                "url": {
                  "raw": "{{BASE_URL}}/meta/ad-creatives/images?ad_account_id={{AD_ACCOUNT_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "ad-creatives", "images"],
                  "query": [
                    { "key": "ad_account_id", "value": "{{AD_ACCOUNT_ID}}" }
                  ]
                },
                "description": "Upload an image (max 10MB). Returns image_hash for use in Create Ad Creative."
              },
              "response": []
            },
            {
              "name": "Update Ad Creative",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Creative Name\"\n}",
                  "options": { "raw": { "language": "json" } }
