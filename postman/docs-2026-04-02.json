                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Test Creative\",\n  \"page_id\": \"REPLACE_WITH_PAGE_ID\",\n  \"message\": \"Check out our offer!\",\n  \"headline\": \"Great Headline\",\n  \"description\": \"Short description here.\",\n  \"link_url\": \"https://example.com\",\n  \"image_hash\": \"REPLACE_WITH_IMAGE_HASH\",\n  \"call_to_action_type\": \"LEARN_MORE\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{BASE_URL}}/meta/ad-creatives?ad_account_id={{AD_ACCOUNT_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "ad-creatives"],
                  "query": [
                    { "key": "ad_account_id", "value": "{{AD_ACCOUNT_ID}}" }
                  ]
                },
                "description": "Use either picture (external URL) or image_hash (from Upload Image).\ncall_to_action_type: LEARN_MORE | SHOP_NOW | SIGN_UP | CONTACT_US | APPLY_NOW | BUY_NOW | GET_QUOTE | SUBSCRIBE | WATCH_MORE | NO_BUTTON | etc."
              },
              "response": []
