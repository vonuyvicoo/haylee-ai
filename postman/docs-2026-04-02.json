              "name": "Update Ad Set",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Ad Set\",\n  \"status\": \"ACTIVE\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{BASE_URL}}/meta/ad-sets/{{ADSET_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "ad-sets", "{{ADSET_ID}}"]
                }
              },
              "response": []
