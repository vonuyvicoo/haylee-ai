        {
          "name": "Campaigns",
          "item": [
            {
              "name": "Get Campaigns",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{BASE_URL}}/meta/campaigns?ad_account_id={{AD_ACCOUNT_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "campaigns"],
                  "query": [
                    { "key": "ad_account_id", "value": "{{AD_ACCOUNT_ID}}" },
                    { "key": "after", "value": "", "disabled": true }
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Create Campaign",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Test Campaign\",\n  \"objective\": \"OUTCOME_LEADS\",\n  \"strategy\": \"CAMPAIGN_BUDGET\",\n  \"daily_budget\": 10000,\n  \"bid_strategy\": \"LOWEST_COST_WITHOUT_CAP\",\n  \"special_ad_categories\": [\"NONE\"]\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{BASE_URL}}/meta/campaigns?ad_account_id={{AD_ACCOUNT_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "campaigns"],
                  "query": [
                    { "key": "ad_account_id", "value": "{{AD_ACCOUNT_ID}}" }
                  ]
                },
                "description": "objective: OUTCOME_APP_PROMOTION | OUTCOME_AWARENESS | OUTCOME_ENGAGEMENT | OUTCOME_LEADS | OUTCOME_SALES | OUTCOME_TRAFFIC\nstrategy: CAMPAIGN_BUDGET | ADSET_BUDGET\nbid_strategy: LOWEST_COST_WITHOUT_CAP | LOWEST_COST_WITH_BID_CAP | COST_CAP | etc.\ndaily_budget / lifetime_budget: in cents. Required when strategy=CAMPAIGN_BUDGET."
              },
              "response": []
            },
            {
              "name": "Update Campaign",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Campaign Name\",\n  \"status\": \"ACTIVE\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{BASE_URL}}/meta/campaigns/{{CAMPAIGN_ID}}?ad_account_id={{AD_ACCOUNT_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "campaigns", "{{CAMPAIGN_ID}}"],
                  "query": [
                    { "key": "ad_account_id", "value": "{{AD_ACCOUNT_ID}}" }
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Delete Campaign",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{BASE_URL}}/meta/campaigns/{{CAMPAIGN_ID}}?ad_account_id={{AD_ACCOUNT_ID}}",
                  "host": ["{{BASE_URL}}"],
                  "path": ["meta", "campaigns", "{{CAMPAIGN_ID}}"],
                  "query": [
                    { "key": "ad_account_id", "value": "{{AD_ACCOUNT_ID}}" }
